# Supabase — copy from your project's API settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — NEVER expose to client. Server-side only.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin panel password
ADMIN_PASSWORD=zuberi2025

# Session secret for signing admin tokens (generate a random 32-char string)
ADMIN_SESSION_SECRET=change-this-to-something-long-and-random
